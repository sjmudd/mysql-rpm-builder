#!/bin/sh
#
# Thin compatibility wrapper so the historical invocation still works:
#
#     ./build_one [-n] <os> <label>      e.g. ./build_one ol10 9.7.1
#
# It simply forwards to the mysql-rpm-builder binary's build-one subcommand.
# Build the binary first with: go build -o mysql-rpm-builder ./go/cmd
#
dir=$(cd "$(dirname "$0")" && pwd)
bin=$dir/mysql-rpm-builder

if [ ! -x "$bin" ]; then
	echo "ERROR: $bin not found or not executable; build it with:" >&2
	echo "    (cd $dir && go build -o mysql-rpm-builder ./go/cmd)" >&2
	exit 1
fi

exec "$bin" build-one "$@"
